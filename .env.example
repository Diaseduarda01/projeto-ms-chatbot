# Banco de dados MySQL
DB_USERNAME=root
DB_PASSWORD=root

# Evolution API — gateway WhatsApp
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_GLOBAL_API_KEY=your-global-api-key-here

# Chave interna — deve ser idêntica ao VITE_CHATBOT_KEY do ms-erp-app
INTERNAL_API_KEY=your-internal-api-key-here

# URL base para o webhook configurado na Evolution API ao criar uma Company
# DEV local:  http://localhost:8085
# Docker:     http://dias-chatbot:8085
CHATBOT_WEBHOOK_BASE_URL=http://localhost:8085

# ms-erp-api (agendamento via WhatsApp)
ERP_BASE_URL=http://localhost:3333
ERP_INTERNAL_API_KEY=your-erp-internal-api-key-here
